# Copy this file to .env on the VPS and fill in your proxy credentials.
# .env is gitignored — your secrets stay local.
#
# Usage:
#   cp .env.example .env
#   nano .env
#   bash scripts/p0/spawn-pair.sh   # auto-loads .env if no flags passed

# Proxy host. Either a hostname (Bright Data: brd.superproxy.io) or an IP.
PROXY_HOST=brd.superproxy.io

# Proxy port (Bright Data: 22225, Webshare: 80, Smartproxy: 7000, etc.)
PROXY_PORT=22225

# Proxy type: socks5 OR http-connect
# (Most providers' "HTTPS proxy" is HTTP CONNECT — use http-connect for that.)
PROXY_TYPE=socks5

# Auth — paste exactly what your provider gave you.
# For Bright Data sticky sessions: USERNAME has format "user-zone-X-session-RANDOM"
PROXY_USER=your_proxy_username
PROXY_PASS=your_proxy_password

# Host port to publish ADB on. P0 default: 40000.
ADB_PORT=40000
